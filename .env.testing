# Connection to Docker PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL=postgresql://sentra_user:sentra_password@127.0.0.1:5433/sentra_core_db?schema=public

# Service Ports
PORT_GATEWAY=3333
PORT_CORE=3001
PORT_COMM=3002
PORT_PM=3003
PORT_HRMS=3006

IAM_INVITE_V2=true
ALLOW_PUBLIC_OWNER_SIGNUP=false
CORS_ORIGINS=https://sales.testinglinq.com,https://pm.testinglinq.com,https://hrms.testinglinq.com,https://portal.testinglinq.com,https://vendor.testinglinq.com,https://admin.testinglinq.com
INVITE_ACCEPT_URL_BASE=https://sales.testinglinq.com
SALES_DASHBOARD_URL=https://sales.testinglinq.com
PM_DASHBOARD_URL=https://pm.testinglinq.com
CLIENT_PORTAL_URL=https://portal.testinglinq.com
FRONTEND_URL=https://sales.testinglinq.com

# JWT Configuration
