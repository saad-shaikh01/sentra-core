# Live / production environment for sentracoresystems.com
# Uses different localhost ports so it can run on the same VPS as testing.

# Service ports on VPS
PORT_GATEWAY=3133
PORT_CORE=3101
PORT_COMM=3102
PORT_PM=3103
PORT_HRMS=3104

# Public URLs
CORS_ORIGINS=https://sales.sentracoresystems.com,https://prod.sentracoresystems.com,https://hrms.sentracoresystems.com,https://portal.sentracoresystems.com,https://vendor.sentracoresystems.com,https://admin.sentracoresystems.com
FRONTEND_URL=https://sales.sentracoresystems.com
INVITE_ACCEPT_URL_BASE=https://sales.sentracoresystems.com
SALES_DASHBOARD_URL=https://sales.sentracoresystems.com
PM_DASHBOARD_URL=https://prod.sentracoresystems.com
CLIENT_PORTAL_URL=https://portal.sentracoresystems.com

# Databases / queues
DATABASE_URL=postgresql://sentra_live_user:change-me-live-postgres@127.0.0.1:5434/sentra_live_db?schema=public
MONGO_URI=mongodb://sentra_live_mongo:change-me-live-mongo@127.0.0.1:27018/sentra_comm_live?authSource=admin
REDIS_URL=redis://:change-me-live-redis@127.0.0.1:6381
CACHE_TTL=300
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# JWT / internal auth
JWT_ACCESS_SECRET=replace-with-live-access-secret
JWT_REFRESH_SECRET=replace-with-live-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
INTERNAL_SERVICE_SECRET=replace-with-live-internal-secret
COMM_ENCRYPTION_MASTER_KEY=replace-with-64-char-hex-string

# Gmail / comm-service
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://api.sentracoresystems.com/api/comm/identities/oauth/callback
GSUITE_REDIRECT_URI=https://api.sentracoresystems.com/api/comm/gsuite/oauth/callback
GOOGLE_PUBSUB_TOPIC=
CORE_SERVICE_URL=http://127.0.0.1:3101

# SMTP
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# Wasabi / Bunny
WASABI_ENDPOINT=https://s3.us-central-1.wasabisys.com
WASABI_REGION=us-central-1
WASABI_BUCKET=sentra-assets-live
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
BUNNY_CDN_HOSTNAME=
BUNNY_CDN_BASE_URL=

# Authorize.net
AUTHORIZE_NET_ENVIRONMENT=sandbox
AUTHORIZE_NET_API_LOGIN_ID=
AUTHORIZE_NET_TRANSACTION_KEY=
AUTHORIZE_NET_WEBHOOK_SIGNATURE=

# Optional attachment archival for comm-service
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
