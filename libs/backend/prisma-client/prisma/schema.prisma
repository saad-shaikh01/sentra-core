// libs/backend/prisma-client/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 0. ENUMS
// ==========================================

enum UserRole {
  OWNER
  ADMIN
  SALES_MANAGER
  PROJECT_MANAGER
  FRONTSELL_AGENT
  UPSELL_AGENT
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  PROPOSAL
  FOLLOW_UP
  CLOSED_WON
  CLOSED_LOST
}

enum LeadType {
  CHAT
  SIGNUP
  SOCIAL
  REFERRAL
  INBOUND
}

enum LeadSource {
  PPC
  SMM
  COLD_REFERRAL
  FACEBOOK_ADS
  WEBHOOK
}

enum ClientStatus {
  ACTIVE
  COMPLETED
  INACTIVE
  REFUNDED
  CHARGEBACK
  BLACKLISTED
}

enum ClientActivityType {
  CREATED
  UPSELL_ASSIGNED
  PM_ASSIGNED
  STATUS_CHANGE
  NOTE
  PORTAL_ACCESS_GRANTED
  PORTAL_ACCESS_REVOKED
  CHARGEBACK_FILED
  REFUND_ISSUED
}

enum SaleStatus {
  DRAFT
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  ON_HOLD
  REFUNDED
}

enum SaleActivityType {
  CREATED
  STATUS_CHANGE
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  REFUND_ISSUED
  CHARGEBACK_FILED
  NOTE
  INVOICE_CREATED
  INVOICE_UPDATED
  MANUAL_ADJUSTMENT
  DISCOUNT_APPLIED
}

enum PaymentPlanType {
  ONE_TIME
  INSTALLMENTS
  SUBSCRIPTION
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum InvoiceStatus {
  UNPAID
  PAID
  OVERDUE
}

enum LeadActivityType {
  STATUS_CHANGE
  NOTE
  ASSIGNMENT_CHANGE
  CONVERSION
  CREATED
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  CHARGEBACK_FILED
  CHARGEBACK_WON
  CHARGEBACK_LOST
}

enum TransactionType {
  ONE_TIME
  RECURRING
  VOID
  REFUND
  CHARGEBACK
}

enum PlanType {
  FREE
  PRO
  ENTERPRISE
}

enum OrganizationOnboardingMode {
  PUBLIC_OWNER_SIGNUP
  INVITE_ONLY
}

enum AppCode {
  SALES_DASHBOARD
  PM_DASHBOARD
  HRMS
  CLIENT_PORTAL
  COMM_SERVICE
}

enum DataScopeType {
  OWN
  TEAM
  DEPARTMENT
  BRAND
  PROJECT
  ALL
}

enum PmProjectOwnerType {
  CLIENT
  INTERNAL_BRAND
}

enum PmEngagementStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum PmServiceType {
  PUBLISHING
  MARKETING
  WEB_DEVELOPMENT
  DESIGN
  GENERAL
}

enum PmProjectType {
  EXTERNAL
  INTERNAL
}

enum PmProjectStatus {
  DRAFT
  ACTIVE
  BLOCKED
  WAITING_APPROVAL
  REVISION_REQUIRED
  COMPLETED
  CANCELLED
}

enum PmProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PmHealthStatus {
  ON_TRACK
  AT_RISK
  OFF_TRACK
  BLOCKED
}

enum PmDepartmentCode {
  DESIGN
  EDITING
  MARKETING
  DEVELOPMENT
  QC
  OPERATIONS
}

enum PmClientReviewMode {
  NONE
  OPTIONAL
  REQUIRED
}

enum PmStageStatus {
  PENDING
  READY
  ACTIVE
  IN_REVIEW
  BLOCKED
  COMPLETED
  SKIPPED
}

enum PmTaskStatus {
  PENDING
  READY
  IN_PROGRESS
  SUBMITTED
  IN_QC
  REVISION_REQUIRED
  COMPLETED
  BLOCKED
  CANCELLED
}

enum PmTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PmDependencyType {
  FINISH_TO_START
  START_TO_START
  FINISH_TO_FINISH
}

enum PmChecklistType {
  SELF_QC
  QC_REVIEW
}

enum PmAssignmentType {
  MANUAL
  CLAIM
  REASSIGN
  AUTO
}

enum PmSubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

enum PmReviewDecision {
  APPROVED
  REJECTED
}

enum PmRevisionSourceType {
  INTERNAL
  CLIENT
  APPROVER
}

enum PmRevisionStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum PmDeliverableType {
  CLIENT
  INTERNAL
}

enum PmApprovalTargetType {
  CLIENT
  INTERNAL_APPROVER
}

enum PmApprovalRequestStatus {
  PENDING
  SENT
  VIEWED
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum PmApprovalDecision {
  APPROVED
  REJECTED
}

enum PmThreadScopeType {
  PROJECT
  STAGE
  TASK
  APPROVAL
}

enum PmThreadVisibility {
  INTERNAL
  EXTERNAL
}

enum PmMessageType {
  COMMENT
  STATUS_NOTE
  APPROVAL_NOTE
  SYSTEM
}

enum PmFileAssetType {
  REFERENCE
  WORKING
  SUBMISSION
  REVIEW_FEEDBACK
  FINAL_DELIVERABLE
  APPROVED_VERSION
}

enum PmFileScopeType {
  PROJECT
  STAGE
  TASK
  SUBMISSION
  DELIVERABLE
  MESSAGE
}

enum PmFileLinkType {
  PRIMARY
  REFERENCE
  ATTACHMENT
  PUBLISHED
  APPROVED
}

enum PmFileActionType {
  PREVIEW
  DOWNLOAD
  SHARE
}

enum PmNotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum PmEscalationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PmEscalationStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum PmPerformancePeriodType {
  WEEKLY
  MONTHLY
  QUARTERLY
}

enum PmDeptMemberRole {
  LEAD
  MEMBER
}

// ==========================================
// 1. MULTI-TENANCY CORE
// ==========================================

model Organization {
  id             String                     @id @default(uuid())
  name           String // e.g., "Madcom Digital"
  subscription   String                     @default("FREE") // "STARTER", "ENTERPRISE"
  planType       PlanType                   @default(FREE)
  onboardingMode OrganizationOnboardingMode @default(PUBLIC_OWNER_SIGNUP)

  brands      Brand[]
  users       User[]
  leads       Lead[]
  clients     Client[]
  sales       Sale[]
  invitations Invitation[]
  appRoles    AppRole[]
  userAppAccesses UserAppAccess[]
  userAppRoles UserAppRole[]
  userScopeGrants UserScopeGrant[]
  salesTeams  SalesTeam[]
  packages    ProductPackage[]
  facebookIntegrations FacebookIntegration[]
  genericLeadWebhooks GenericLeadWebhook[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// SALES TEAMS
// ==========================================

model SalesTeam {
  id             String @id @default(uuid())
  name           String
  description    String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  managers SalesTeamManager[]
  members  SalesTeamMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model SalesTeamManager {
  teamId String
  team   SalesTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String
  user   User      @relation("TeamManagers", fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
}

model SalesTeamMember {
  teamId String
  team   SalesTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String
  user   User      @relation("TeamMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
}

// ==========================================
// PRODUCT PACKAGES / SERVICE CATALOG
// ==========================================

model ProductPackage {
  id             String  @id @default(uuid())
  name           String
  description    String?
  isActive       Boolean @default(true)

  brandId        String?
  brand          Brand?  @relation(fields: [brandId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  items PackageItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, brandId])
}

model PackageItem {
  id          String  @id @default(uuid())
  name        String
  description String?
  unitPrice   Decimal @db.Decimal(10, 2)
  isActive    Boolean @default(true)

  packageId String
  package   ProductPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
}

model Brand {
  id                 String  @id @default(uuid())
  name               String // e.g., "The Pulp House"
  domain             String? @unique
  portalDomain       String? @unique
  portalSubdomain    String? @unique
  customPortalDomain String? @unique

  // Branding Assets
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String? // hex e.g. "#6366F1"
  secondaryColor String? // hex
  colors         Json?
  themeConfig    Json?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  leads        Lead[]
  clients      Client[]
  sales        Sale[]
  emailAliases EmailAlias[]
  packages     ProductPackage[]
  facebookIntegrations FacebookIntegration[]
  genericLeadWebhooks GenericLeadWebhook[]

  members BrandAccess[]

  @@index([organizationId])
}

// ==========================================
// 2. IAM & AGENT MANAGEMENT
// ==========================================

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String // Hashed
  name     String
  role     UserRole @default(FRONTSELL_AGENT)

  // Profile Fields
  avatarUrl String?
  jobTitle  String?
  phone     String?
  bio       String?
  isActive  Boolean @default(true) // For soft delete

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Permissions & Access
  accessScope BrandAccess[]
  appAccesses UserAppAccess[]
  appRoles    UserAppRole[]
  scopeGrants UserScopeGrant[]
  createdAppRoles AppRole[] @relation("AppRoleCreatedBy")
  emailConfig UserEmailConfig? // Gmail Integration

  assignedLeads      Lead[]
  leadActivities     LeadActivity[]
  clientActivities   ClientActivity[]
  saleActivities     SaleActivity[]
  upsellClients      Client[]           @relation("ClientUpsellAgent")
  managedClients     Client[]           @relation("ClientProjectManager")
  managedTeams       SalesTeamManager[] @relation("TeamManagers")
  memberOfTeams      SalesTeamMember[]  @relation("TeamMembers")

  // Status
  status        UserStatus @default(ACTIVE)
  suspendedAt   DateTime?
  suspendedBy   String?
  suspendReason String?
  deactivatedAt DateTime?

  // Refresh Tokens (sessions)
  refreshTokens RefreshToken[]

  // Password Reset
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, email])
}

model BrandAccess {
  id      String @id @default(uuid())
  userId  String
  brandId String
  role    String // "VIEWER", "EDITOR", "ADMIN"

  user  User  @relation(fields: [userId], references: [id])
  brand Brand @relation(fields: [brandId], references: [id])

  @@unique([userId, brandId]) // User can't have duplicate roles for same brand
}

model Invitation {
  id        String           @id @default(uuid())
  email     String
  role      UserRole?
  token     String           @unique // Unique token for invitation link
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  invitedById String // The user who sent the invitation
  bundles    InvitationBundle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, email])
  @@index([token])
}

model AppRegistry {
  id          String   @id @default(uuid())
  code        AppCode  @unique
  name        String
  baseUrl     String?
  description String?
  isActive    Boolean  @default(true)

  permissionCatalog PermissionCatalog[]
  appRoles          AppRole[]
  userAppAccesses   UserAppAccess[]
  userAppRoles      UserAppRole[]
  userScopeGrants   UserScopeGrant[]
  invitationBundles InvitationBundle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PermissionCatalog {
  id          String @id @default(uuid())
  appId       String
  key         String
  label       String
  description String?
  isActive    Boolean @default(true)

  app      AppRegistry         @relation(fields: [appId], references: [id], onDelete: Cascade)
  roleLinks AppRolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([appId, key])
  @@index([appId, isActive])
}

model AppRole {
  id             String  @id @default(uuid())
  organizationId String
  appId          String
  name           String
  slug           String
  description    String?
  isSystem       Boolean @default(false)
  isActive       Boolean @default(true)
  createdById    String?

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  app          AppRegistry        @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdBy    User?              @relation("AppRoleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  permissions  AppRolePermission[]
  users        UserAppRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, appId, slug])
  @@index([organizationId, appId, isActive])
}

model AppRolePermission {
  id           String @id @default(uuid())
  appRoleId    String
  permissionId String

  appRole    AppRole          @relation(fields: [appRoleId], references: [id], onDelete: Cascade)
  permission PermissionCatalog @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([appRoleId, permissionId])
  @@index([permissionId])
}

model UserAppAccess {
  id             String  @id @default(uuid())
  organizationId String
  userId         String
  appId          String
  isEnabled      Boolean @default(true)
  isDefault      Boolean @default(false)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  app          AppRegistry  @relation(fields: [appId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userId, appId])
  @@index([userId, isEnabled])
  @@index([organizationId, appId, isEnabled])
}

model UserAppRole {
  id             String  @id @default(uuid())
  organizationId String
  userId         String
  appId          String
  appRoleId      String
  isPrimary      Boolean @default(false)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  app          AppRegistry  @relation(fields: [appId], references: [id], onDelete: Cascade)
  appRole      AppRole      @relation(fields: [appRoleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userId, appId, appRoleId])
  @@index([organizationId, userId, appId])
}

model UserScopeGrant {
  id             String        @id @default(uuid())
  organizationId String
  userId         String
  appId          String
  resourceKey    String
  scopeType      DataScopeType
  scopeValues    Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  app          AppRegistry  @relation(fields: [appId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, userId, appId])
  @@index([appId, resourceKey, scopeType])
}

model InvitationBundle {
  id           String @id @default(uuid())
  invitationId String
  appId        String
  roleIds      Json?
  scopeGrants  Json?

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  app        AppRegistry @relation(fields: [appId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([invitationId, appId])
  @@index([invitationId])
}

// ==========================================
// 3. EMAIL INTEGRATION (Gmail Aliases)
// ==========================================

model UserEmailConfig {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  primaryEmail String // "mark@publishing.com"
  accessToken  String // Encrypted
  refreshToken String // Encrypted

  aliases EmailAlias[]
}

model EmailAlias {
  id          String  @id @default(uuid())
  email       String // "mark@urbanquill.com"
  displayName String? // "Mark - Urban Quill"

  configId String
  config   UserEmailConfig @relation(fields: [configId], references: [id])

  linkedBrandId String?
  linkedBrand   Brand?  @relation(fields: [linkedBrandId], references: [id])
}

// ==========================================
// 4. BUSINESS FLOW (Sales Engine)
// ==========================================

model Lead {
  id       String      @id @default(uuid())
  title    String? // Optional: auto-generated from name/email/source if not provided
  name     String? // Client Name
  email    String? // Client Email
  phone    String? // Client Phone
  website  String? // Client Website
  status   LeadStatus  @default(NEW)
  leadType LeadType? // CHAT, SIGNUP, SOCIAL, REFERRAL, INBOUND
  source   LeadSource? // PPC, SMM, COLD_REFERRAL
  leadDate DateTime? // When the lead was originally captured
  lostReason String? // Reason when status = CLOSED_LOST
  data     Json? // Flexible Form Data (Extra fields)

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])

  convertedClientId String? @unique // Link if converted

  followUpDate DateTime? // Required when status = FOLLOW_UP
  deletedAt    DateTime? // Soft-delete timestamp

  activities LeadActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, brandId, status]) // Performance Index for Dashboard
  @@index([organizationId, deletedAt])       // Soft-delete filter index
}

model LeadActivity {
  id   String           @id @default(uuid())
  type LeadActivityType
  data Json // Stores context based on type

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId String // Who performed the action
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

model FacebookIntegration {
  id          String   @id @default(uuid())
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brandId     String
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  pageId      String
  formId      String
  accessToken String
  isActive    Boolean  @default(true)
  label       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([pageId, formId])
  @@index([organizationId, isActive])
  @@index([brandId])
}

model GenericLeadWebhook {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brandId        String
  brand          Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  label          String?
  signingSecret  String
  defaultSource  LeadSource?
  defaultLeadType LeadType?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, isActive])
  @@index([brandId])
}

model Client {
  id          String       @id @default(uuid())
  email       String
  companyName String
  contactName String?
  phone       String?
  address     String?
  notes       String?
  status      ClientStatus @default(ACTIVE)

  // Portal access
  portalAccess    Boolean   @default(false)
  portalGrantedAt DateTime?
  portalGrantedBy String?
  emailVerified   Boolean   @default(false)
  emailOtp        String?
  emailOtpExpiry  DateTime?
  mustSetPassword Boolean   @default(true)

  // Assignment
  upsellAgentId     String?
  upsellAgent       User?   @relation("ClientUpsellAgent", fields: [upsellAgentId], references: [id])
  projectManagerId  String?
  projectManager    User?   @relation("ClientProjectManager", fields: [projectManagerId], references: [id])

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  sales      Sale[]
  activities ClientActivity[]

  deletedAt DateTime? // Soft-delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, organizationId])
  @@index([organizationId, status])
  @@index([upsellAgentId])
  @@index([projectManagerId])
}

model Sale {
  id          String     @id @default(uuid())
  totalAmount Decimal    @db.Decimal(10, 2)
  status      SaleStatus @default(PENDING)
  currency    String     @default("USD")
  description String?
  contractUrl String? // Optional uploaded contract file URL

  // Payment plan config
  paymentPlan     PaymentPlanType @default(ONE_TIME)
  installmentCount Int?            // Number of installments (null = 1)
  discountType     DiscountType?
  discountValue    Decimal?        @db.Decimal(10, 2)
  discountedTotal  Decimal?        @db.Decimal(10, 2)

  // Authorize.net fields
  customerProfileId String?
  paymentProfileId  String?
  subscriptionId    String?

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  items        SaleItem[]
  invoices     Invoice[]
  transactions PaymentTransaction[]
  activities   SaleActivity[]

  deletedAt DateTime? // Soft-delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, brandId, status])
  @@index([clientId])
  @@index([subscriptionId])
}

model SaleItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10, 2)
  customPrice Decimal? @db.Decimal(10, 2) // Price override for custom plans
  packageId   String?
  packageName String?

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([saleId])
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  amount        Decimal       @db.Decimal(10, 2)
  dueDate       DateTime
  status        InvoiceStatus @default(UNPAID)
  pdfUrl        String?
  notes         String?
  paymentToken  String?       @unique

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id])

  transactions PaymentTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([saleId])
  @@index([status, dueDate])
}

model PaymentTransaction {
  id              String            @id @default(uuid())
  transactionId   String? // Authorize.net reference
  type            TransactionType
  amount          Decimal           @db.Decimal(10, 2)
  status          TransactionStatus @default(PENDING)
  responseCode    String?
  responseMessage String?

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([transactionId])
}

model ClientActivity {
  id   String             @id @default(uuid())
  type ClientActivityType
  data Json // Context based on type

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  userId String // Who performed the action
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([clientId, createdAt])
}

model SaleActivity {
  id   String           @id @default(uuid())
  type SaleActivityType
  data Json

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([saleId, createdAt])
}

model InvoiceSequence {
  id      String @id @default(uuid())
  brandId String @unique
  year    Int
  lastSeq Int    @default(0)

  @@index([brandId, year])
}

// ==========================================
// 5. RELIABILITY (Transactional Outbox)
// ==========================================

model OutboxEvent {
  id        String   @id @default(uuid())
  eventType String // "ORDER_CREATED", "LEAD_ASSIGNED"
  payload   Json
  status    String   @default("PENDING") // "PROCESSING", "COMPLETED", "FAILED"
  createdAt DateTime @default(now())

  @@index([status, createdAt]) // Worker will poll PENDING events fast
}

// ==========================================
// 6. PROJECT MANAGEMENT DOMAIN
// ==========================================

model PmServiceTemplate {
  id             String        @id @default(uuid())
  organizationId String
  brandId        String?
  name           String
  serviceType    PmServiceType
  description    String?
  isActive       Boolean       @default(true)
  isDefault      Boolean       @default(false)
  version        Int           @default(1)
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  stages   PmTemplateStage[]
  projects PmProject[]

  @@index([organizationId, isActive, serviceType])
  @@index([brandId])
}

model PmTemplateStage {
  id                    String             @id @default(uuid())
  templateId            String
  name                  String
  description           String?
  departmentCode        PmDepartmentCode
  sortOrder             Int
  defaultSlaHours       Int?
  clientReviewMode      PmClientReviewMode @default(NONE)
  requiresStageApproval Boolean            @default(false)
  requiresQcByDefault   Boolean            @default(false)
  isOptional            Boolean            @default(false)
  allowsParallel        Boolean            @default(false)

  template      PmServiceTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tasks         PmTemplateTask[]
  checklists    PmTemplateChecklist[]
  projectStages PmProjectStage[]
  dependencies  PmTemplateStageDependency[] @relation("PmTemplateStageDependencies")
  dependsOn     PmTemplateStageDependency[] @relation("PmTemplateStageDependencyTargets")

  @@unique([templateId, name])
  @@index([templateId, sortOrder])
}

model PmTemplateStageDependency {
  id                       String           @id @default(uuid())
  templateStageId          String
  dependsOnTemplateStageId String
  dependencyType           PmDependencyType @default(FINISH_TO_START)

  templateStage          PmTemplateStage @relation("PmTemplateStageDependencies", fields: [templateStageId], references: [id], onDelete: Cascade)
  dependsOnTemplateStage PmTemplateStage @relation("PmTemplateStageDependencyTargets", fields: [dependsOnTemplateStageId], references: [id], onDelete: Cascade)

  @@unique([templateStageId, dependsOnTemplateStageId])
  @@index([templateStageId])
}

model PmTemplateTask {
  id                  String    @id @default(uuid())
  templateStageId     String
  name                String
  description         String?
  sortOrder           Int
  defaultAssigneeRole UserRole?
  requiresQc          Boolean   @default(false)
  isRequired          Boolean   @default(true)
  estimatedHours      Int?

  templateStage PmTemplateStage       @relation(fields: [templateStageId], references: [id], onDelete: Cascade)
  checklists    PmTemplateChecklist[]
  tasks         PmTask[]

  @@unique([templateStageId, name])
  @@index([templateStageId, sortOrder])
}

model PmTemplateChecklist {
  id              String          @id @default(uuid())
  templateStageId String?
  templateTaskId  String?
  checklistType   PmChecklistType
  label           String
  sortOrder       Int
  isRequired      Boolean         @default(true)

  templateStage   PmTemplateStage?   @relation(fields: [templateStageId], references: [id], onDelete: Cascade)
  templateTask    PmTemplateTask?    @relation(fields: [templateTaskId], references: [id], onDelete: Cascade)
  selfQcResponses PmSelfQcResponse[]

  @@index([templateStageId, checklistType])
  @@index([templateTaskId, checklistType])
}

model PmEngagement {
  id             String             @id @default(uuid())
  organizationId String
  ownerType      PmProjectOwnerType
  clientId       String?
  ownerBrandId   String?
  primaryBrandId String?
  name           String
  description    String?
  status         PmEngagementStatus @default(DRAFT)
  priority       PmProjectPriority  @default(MEDIUM)
  saleId         String?
  createdById    String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  projects PmProject[]

  @@index([organizationId, status, createdAt])
  @@index([clientId])
  @@index([ownerBrandId])
  @@index([saleId])
}

model PmProject {
  id             String            @id @default(uuid())
  organizationId String
  engagementId   String
  brandId        String
  clientId       String?
  templateId     String?
  projectType    PmProjectType
  serviceType    PmServiceType
  name           String
  description    String?
  status         PmProjectStatus   @default(DRAFT)
  priority       PmProjectPriority @default(MEDIUM)
  healthStatus   PmHealthStatus    @default(ON_TRACK)
  deliveryDueAt  DateTime?
  publishedAt    DateTime?
  closedAt       DateTime?
  createdById    String
  updatedById    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  engagement            PmEngagement             @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  template              PmServiceTemplate?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  stages                PmProjectStage[]
  stageDependencies     PmStageDependency[]
  tasks                 PmTask[]
  revisionRequests      PmRevisionRequest[]
  deliverablePackages   PmDeliverablePackage[]
  approvalRequests      PmApprovalRequest[]
  closureRecords        PmProjectClosureRecord[]
  threads               PmConversationThread[]
  fileAssets            PmFileAsset[]
  notifications         PmNotification[]
  activityLogs          PmActivityLog[]
  escalationEvents      PmEscalationEvent[]
  performanceEvents     PmPerformanceEvent[]
  clientPortalAccesses  PmClientPortalAccess[]

  @@index([organizationId, brandId, status, deliveryDueAt])
  @@index([engagementId])
  @@index([templateId])
}

model PmProjectStage {
  id                    String             @id @default(uuid())
  organizationId        String
  projectId             String
  templateStageId       String?
  name                  String
  description           String?
  departmentCode        PmDepartmentCode
  status                PmStageStatus      @default(PENDING)
  sortOrder             Int
  ownerLeadId           String?
  clientReviewMode      PmClientReviewMode @default(NONE)
  requiresStageApproval Boolean            @default(false)
  requiresQcByDefault   Boolean            @default(false)
  isOptional            Boolean            @default(false)
  isBlocked             Boolean            @default(false)
  startedAt             DateTime?
  dueAt                 DateTime?
  completedAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  project          PmProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateStage    PmTemplateStage?    @relation(fields: [templateStageId], references: [id], onDelete: SetNull)
  tasks            PmTask[]
  dependencies     PmStageDependency[] @relation("PmProjectStageDependencies")
  dependsOn        PmStageDependency[] @relation("PmProjectStageDependencyTargets")
  bypassRecords    PmBypassRecord[]
  escalationEvents PmEscalationEvent[]

  @@unique([projectId, name])
  @@index([projectId, sortOrder, status])
  @@index([ownerLeadId, status])
}

model PmStageDependency {
  id                      String           @id @default(uuid())
  projectId               String
  projectStageId          String
  dependsOnProjectStageId String
  dependencyType          PmDependencyType @default(FINISH_TO_START)

  project               PmProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectStage          PmProjectStage @relation("PmProjectStageDependencies", fields: [projectStageId], references: [id], onDelete: Cascade)
  dependsOnProjectStage PmProjectStage @relation("PmProjectStageDependencyTargets", fields: [dependsOnProjectStageId], references: [id], onDelete: Cascade)

  @@unique([projectStageId, dependsOnProjectStageId])
  @@index([projectId])
}

model PmTask {
  id             String         @id @default(uuid())
  organizationId String
  projectId      String
  projectStageId String
  templateTaskId String?
  name           String
  description    String?
  status         PmTaskStatus   @default(PENDING)
  priority       PmTaskPriority @default(MEDIUM)
  sortOrder      Int
  ownerLeadId    String?
  assigneeId     String?
  requiresQc     Boolean        @default(false)
  isRequired     Boolean        @default(true)
  isBlocked      Boolean        @default(false)
  startedAt      DateTime?
  dueAt          DateTime?
  submittedAt    DateTime?
  completedAt    DateTime?
  departmentCode PmDepartmentCode?
  createdById    String
  updatedById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  project           PmProject            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectStage      PmProjectStage       @relation(fields: [projectStageId], references: [id], onDelete: Cascade)
  templateTask      PmTemplateTask?      @relation(fields: [templateTaskId], references: [id], onDelete: SetNull)
  assignments       PmTaskAssignment[]
  worklogs          PmTaskWorklog[]
  submissions       PmTaskSubmission[]
  bypassRecords     PmBypassRecord[]
  revisionRequests  PmRevisionRequest[]
  escalationEvents  PmEscalationEvent[]
  performanceEvents PmPerformanceEvent[]
  pmQcReviews       PmQcReview[]

  @@index([organizationId, assigneeId, status, dueAt])
  @@index([projectStageId, sortOrder, status])
  @@index([projectId, status])
  @@index([organizationId, departmentCode, status])
}

model PmTaskAssignment {
  id             String           @id @default(uuid())
  taskId         String
  assignedById   String
  assignedToId   String
  assignmentType PmAssignmentType @default(MANUAL)
  startedAt      DateTime         @default(now())
  endedAt        DateTime?
  isCurrent      Boolean          @default(true)
  notes          String?

  task PmTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, isCurrent])
  @@index([assignedToId, isCurrent])
}

model PmTaskWorklog {
  id              String    @id @default(uuid())
  taskId          String
  userId          String
  startedAt       DateTime
  endedAt         DateTime?
  durationMinutes Int?
  notes           String?
  createdAt       DateTime  @default(now())

  task PmTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, startedAt])
  @@index([userId, startedAt])
}

model PmTaskSubmission {
  id               String             @id @default(uuid())
  taskId           String
  submittedById    String
  submissionNumber Int
  status           PmSubmissionStatus @default(SUBMITTED)
  notes            String?
  submittedAt      DateTime           @default(now())

  task             PmTask              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  selfQcResponses  PmSelfQcResponse[]
  qcReviews        PmQcReview[]
  deliverableItems PmDeliverableItem[]

  @@unique([taskId, submissionNumber])
  @@index([taskId, submissionNumber])
}

model PmSelfQcResponse {
  id                  String  @id @default(uuid())
  taskSubmissionId    String
  templateChecklistId String?
  labelSnapshot       String
  isChecked           Boolean @default(false)
  responseText        String?

  taskSubmission    PmTaskSubmission     @relation(fields: [taskSubmissionId], references: [id], onDelete: Cascade)
  templateChecklist PmTemplateChecklist? @relation(fields: [templateChecklistId], references: [id], onDelete: SetNull)

  @@index([taskSubmissionId])
}

model PmQcReview {
  id               String           @id @default(uuid())
  taskId           String
  taskSubmissionId String
  reviewerId       String
  decision         PmReviewDecision
  reviewNumber     Int
  feedback         String?
  reviewedAt       DateTime         @default(now())

  task           PmTask           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskSubmission PmTaskSubmission @relation(fields: [taskSubmissionId], references: [id], onDelete: Cascade)

  @@unique([taskSubmissionId, reviewNumber])
  @@index([taskId, reviewedAt])
}

model PmBypassRecord {
  id             String   @id @default(uuid())
  taskId         String?
  projectStageId String?
  actedById      String
  reason         String
  redFlag        Boolean  @default(true)
  createdAt      DateTime @default(now())

  task         PmTask?         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  projectStage PmProjectStage? @relation(fields: [projectStageId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([projectStageId])
}

model PmRevisionRequest {
  id           String               @id @default(uuid())
  projectId    String
  taskId       String?
  sourceType   PmRevisionSourceType
  sourceUserId String?
  requestType  String
  status       PmRevisionStatus     @default(OPEN)
  notes        String?
  createdAt    DateTime             @default(now())
  resolvedAt   DateTime?

  project PmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    PmTask?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([projectId, status, createdAt])
  @@index([taskId])
}

model PmDeliverablePackage {
  id           String            @id @default(uuid())
  projectId    String
  name         String
  description  String?
  deliveryType PmDeliverableType
  createdById  String
  createdAt    DateTime          @default(now())

  project          PmProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items            PmDeliverableItem[]
  approvalRequests PmApprovalRequest[]

  @@index([projectId, createdAt])
}

model PmDeliverableItem {
  id                   String  @id @default(uuid())
  deliverablePackageId String
  taskSubmissionId     String?
  fileAssetId          String?
  fileVersionId        String?
  sortOrder            Int     @default(0)
  label                String?

  deliverablePackage PmDeliverablePackage @relation(fields: [deliverablePackageId], references: [id], onDelete: Cascade)
  taskSubmission     PmTaskSubmission?    @relation(fields: [taskSubmissionId], references: [id], onDelete: SetNull)
  fileAsset          PmFileAsset?         @relation(fields: [fileAssetId], references: [id], onDelete: SetNull)
  fileVersion        PmFileVersion?       @relation(fields: [fileVersionId], references: [id], onDelete: SetNull)

  @@index([deliverablePackageId, sortOrder])
}

model PmApprovalRequest {
  id                   String                  @id @default(uuid())
  projectId            String
  deliverablePackageId String
  approvalTargetType   PmApprovalTargetType
  approvalTargetUserId String?
  approvalTargetEmail  String?
  status               PmApprovalRequestStatus @default(PENDING)
  sentById             String
  sentAt               DateTime?
  dueAt                DateTime?

  project            PmProject            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverablePackage PmDeliverablePackage @relation(fields: [deliverablePackageId], references: [id], onDelete: Cascade)
  snapshots          PmApprovalSnapshot[]

  @@index([projectId, status, sentAt])
  @@index([deliverablePackageId])
}

model PmApprovalSnapshot {
  id                String             @id @default(uuid())
  approvalRequestId String
  decision          PmApprovalDecision
  actedByUserId     String?
  actorIp           String?
  notes             String?
  actedAt           DateTime           @default(now())

  approvalRequest PmApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)

  @@index([approvalRequestId, actedAt])
}

model PmProjectClosureRecord {
  id            String   @id @default(uuid())
  projectId     String
  closedById    String
  closureReason String
  notes         String?
  closedAt      DateTime @default(now())

  project PmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, closedAt])
}

model PmConversationThread {
  id             String             @id @default(uuid())
  organizationId String
  projectId      String
  scopeType      PmThreadScopeType
  scopeId        String
  visibility     PmThreadVisibility @default(INTERNAL)
  createdById    String
  createdAt      DateTime           @default(now())

  project      PmProject             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages     PmMessage[]
  participants PmThreadParticipant[]

  @@unique([projectId, scopeType, scopeId])
  @@index([projectId, scopeType])
}

model PmMessage {
  id              String        @id @default(uuid())
  threadId        String
  authorId        String
  parentMessageId String?
  messageType     PmMessageType @default(COMMENT)
  body            String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  thread        PmConversationThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  parentMessage PmMessage?            @relation("PmMessageReplies", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies       PmMessage[]           @relation("PmMessageReplies")
  mentions      PmMessageMention[]
  attachments   PmMessageAttachment[]

  @@index([threadId, createdAt])
  @@index([parentMessageId])
}

model PmMessageMention {
  id              String   @id @default(uuid())
  messageId       String
  mentionedUserId String
  createdAt       DateTime @default(now())

  message PmMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, mentionedUserId])
  @@index([mentionedUserId, createdAt])
}

model PmMessageAttachment {
  id             String         @id @default(uuid())
  messageId      String
  fileAssetId    String
  fileVersionId  String?
  attachmentType PmFileLinkType @default(ATTACHMENT)

  message     PmMessage      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileAsset   PmFileAsset    @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)
  fileVersion PmFileVersion? @relation(fields: [fileVersionId], references: [id], onDelete: SetNull)

  @@index([messageId])
  @@index([fileAssetId])
}

model PmThreadParticipant {
  id                String    @id @default(uuid())
  threadId          String
  userId            String
  lastReadMessageId String?
  lastReadAt        DateTime?
  isMuted           Boolean   @default(false)

  thread PmConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId, lastReadAt])
}

model PmFileAsset {
  id             String          @id @default(uuid())
  organizationId String
  projectId      String
  assetType      PmFileAssetType
  name           String
  mimeType       String?
  createdById    String
  createdAt      DateTime        @default(now())

  project            PmProject             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions           PmFileVersion[]
  links              PmFileLink[]
  accessLogs         PmFileAccessLog[]
  messageAttachments PmMessageAttachment[]
  deliverableItems   PmDeliverableItem[]

  @@index([organizationId, createdAt])
  @@index([projectId, assetType, createdAt])
}

model PmFileVersion {
  id               String   @id @default(uuid())
  fileAssetId      String
  versionNumber    Int
  storageKey       String   @unique
  originalFilename String
  sizeBytes        Int?
  checksum         String?
  uploadedById     String
  uploadedAt       DateTime @default(now())
  isLatest         Boolean  @default(true)
  isApproved       Boolean  @default(false)
  isPublished      Boolean  @default(false)

  fileAsset          PmFileAsset           @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)
  links              PmFileLink[]
  accessLogs         PmFileAccessLog[]
  messageAttachments PmMessageAttachment[]
  deliverableItems   PmDeliverableItem[]

  @@unique([fileAssetId, versionNumber])
  @@index([fileAssetId, versionNumber])
}

model PmFileLink {
  id            String          @id @default(uuid())
  fileAssetId   String
  fileVersionId String?
  scopeType     PmFileScopeType
  scopeId       String
  linkType      PmFileLinkType  @default(REFERENCE)
  createdById   String
  createdAt     DateTime        @default(now())

  fileAsset   PmFileAsset    @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)
  fileVersion PmFileVersion? @relation(fields: [fileVersionId], references: [id], onDelete: SetNull)

  @@index([scopeType, scopeId])
  @@index([fileAssetId])
  @@index([fileVersionId])
}

model PmFileAccessLog {
  id            String           @id @default(uuid())
  fileAssetId   String
  fileVersionId String?
  userId        String
  actionType    PmFileActionType
  createdAt     DateTime         @default(now())

  fileAsset   PmFileAsset    @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)
  fileVersion PmFileVersion? @relation(fields: [fileVersionId], references: [id], onDelete: SetNull)

  @@index([fileAssetId, createdAt])
  @@index([userId, createdAt])
}

model PmNotification {
  id             String               @id @default(uuid())
  organizationId String
  projectId      String?
  userId         String
  eventType      String
  scopeType      String
  scopeId        String
  status         PmNotificationStatus @default(UNREAD)
  payload        Json?
  createdAt      DateTime             @default(now())
  readAt         DateTime?

  project PmProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([organizationId, createdAt])
}

model PmActivityLog {
  id             String   @id @default(uuid())
  organizationId String
  projectId      String
  scopeType      String
  scopeId        String
  actorUserId    String?
  eventType      String
  payloadJson    Json?
  createdAt      DateTime @default(now())

  project PmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([organizationId, createdAt])
}

model PmEscalationEvent {
  id             String               @id @default(uuid())
  organizationId String
  projectId      String
  taskId         String?
  projectStageId String?
  eventType      String
  severity       PmEscalationSeverity @default(MEDIUM)
  status         PmEscalationStatus   @default(OPEN)
  payloadJson    Json?
  createdAt      DateTime             @default(now())
  resolvedAt     DateTime?

  project      PmProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task         PmTask?         @relation(fields: [taskId], references: [id], onDelete: SetNull)
  projectStage PmProjectStage? @relation(fields: [projectStageId], references: [id], onDelete: SetNull)

  @@index([projectId, status, createdAt])
  @@index([taskId])
  @@index([projectStageId])
}

model PmPerformanceEvent {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  projectId      String
  taskId         String?
  eventType      String
  scoreDelta     Int
  createdAt      DateTime @default(now())

  project PmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    PmTask?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
}

model PmScoreSnapshot {
  id             String                  @id @default(uuid())
  organizationId String
  userId         String
  periodType     PmPerformancePeriodType
  periodStart    DateTime
  periodEnd      DateTime
  scoreValue     Int
  createdAt      DateTime                @default(now())

  @@index([userId, periodStart, periodEnd])
  @@index([organizationId, createdAt])
}

model PmDepartment {
  id             String           @id @default(uuid())
  organizationId String
  code           PmDepartmentCode
  name           String
  description    String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  members PmDepartmentMember[]

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

model PmDepartmentMember {
  id           String           @id @default(uuid())
  departmentId String
  userId       String
  role         PmDeptMemberRole @default(MEMBER)
  joinedAt     DateTime         @default(now())

  department PmDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
}

model PmClientPortalAccess {
  id             String    @id @default(uuid())
  organizationId String
  projectId      String
  clientId       String?
  email          String
  token          String    @unique
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdById    String
  createdAt      DateTime  @default(now())

  project PmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId, isActive])
  @@index([projectId])
}

model Notification {
  id             String           @id @default(cuid())
  type           NotificationType
  message        String
  saleId         String?
  organizationId String
  recipientId    String
  isRead         Boolean          @default(false)
  data           Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId, recipientId])
  @@index([organizationId, type])
}

enum NotificationType {
  PAYMENT_FAILED
  INVOICE_OVERDUE
  SALE_STATUS_CHANGED
  CHARGEBACK_FILED
  PAYMENT_RECEIVED
}

// ==========================================
// AUTH - SESSION TABLE
// ==========================================

model RefreshToken {
  id             String    @id @default(cuid())
  userId         String
  organizationId String?
  appCode        String
  tokenHash      String
  deviceInfo     Json?
  ipAddress      String?
  lastUsedAt     DateTime?
  expiresAt      DateTime
  revokedAt      DateTime?
  revokedReason  String?
  familyId       String
  createdAt      DateTime  @default(now())

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}
