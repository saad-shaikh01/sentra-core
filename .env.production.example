# Backend services
PORT_CORE=3001
PORT_COMM=3002
PORT_PM=3003

# Public URLs
CORS_ORIGINS=https://sales.testinglinq.com,https://pm.testinglinq.com,https://portal.testinglinq.com
FRONTEND_URL=https://sales.testinglinq.com
INVITE_ACCEPT_URL_BASE=https://sales.testinglinq.com
SALES_DASHBOARD_URL=https://sales.testinglinq.com
PM_DASHBOARD_URL=https://pm.testinglinq.com
CLIENT_PORTAL_URL=https://portal.testinglinq.com
NEXT_PUBLIC_API_URL=https://api.example.com/api
NEXT_PUBLIC_CORE_API_URL=https://api.example.com/api
NEXT_PUBLIC_COMM_API_URL=https://api.example.com/api/comm
NEXT_PUBLIC_COMM_WS_URL=https://api.example.com
NEXT_PUBLIC_COMM_WS_PATH=/socket.io-comm/
NEXT_PUBLIC_PM_API_URL=https://api.example.com/api/pm
NEXT_PUBLIC_PM_WS_URL=https://api.example.com
NEXT_PUBLIC_PM_WS_PATH=/socket.io-pm/
NEXT_PUBLIC_HRMS_API_URL=https://api.example.com/api/hrms
NEXT_PUBLIC_COMM_ENABLED=true

# Databases / queues
DATABASE_URL=postgresql://sentra_prod_user:change-me-postgres@127.0.0.1:5433/sentra_core_db?schema=public
MONGO_URI=mongodb://sentra_mongo_user:change-me-mongo@127.0.0.1:27017/sentra_comm?authSource=admin
REDIS_URL=redis://:change-me-redis@127.0.0.1:6380
CACHE_TTL=300
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# JWT / internal auth
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
INTERNAL_SERVICE_SECRET=replace-with-strong-internal-secret
COMM_ENCRYPTION_MASTER_KEY=replace-with-64-char-hex-string

# Gmail / comm-service
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://api.testinglinq.com/api/comm/identities/oauth/callback
GOOGLE_PUBSUB_TOPIC=
CORE_SERVICE_URL=http://127.0.0.1:3001
# Public-facing URL of the core API — used to generate webhook URLs shown to users
PUBLIC_API_URL=https://api.testinglinq.com/api

# SMTP
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# Wasabi / Bunny
WASABI_ENDPOINT=https://s3.us-central-1.wasabisys.com
WASABI_REGION=us-central-1
WASABI_BUCKET=sentra-assets-prod
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
BUNNY_CDN_HOSTNAME=

# Authorize.net
AUTHORIZE_NET_ENVIRONMENT=sandbox
AUTHORIZE_NET_API_LOGIN_ID=
AUTHORIZE_NET_TRANSACTION_KEY=
AUTHORIZE_NET_WEBHOOK_SIGNATURE=

# Optional attachment archival for comm-service
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
