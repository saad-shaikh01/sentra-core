# Connection to Docker PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL="postgresql://sentra_user:sentra_password@localhost:5433/sentra_core_db?schema=public"

# Service Ports
PORT_GATEWAY=3333
PORT_CORE=3001
PORT_COMM=3002


IAM_INVITE_V2=true
ALLOW_PUBLIC_OWNER_SIGNUP=false
INVITE_ACCEPT_URL_BASE=http://localhost:4200
SALES_DASHBOARD_URL=http://localhost:4200
PM_DASHBOARD_URL=http://localhost:4201


# JWT Configuration
JWT_ACCESS_SECRET="sentra-access-secret-change-in-production"
JWT_REFRESH_SECRET="sentra-refresh-secret-change-in-production"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"


SMTP_HOST=smtp.gmail.com 
SMTP_USER=whiteangela.tw@gmail.com
SMTP_PASS=ejkg ijey dxiv jvao
FRONTEND_URL=http://localhost:4200

# Redis Caching
REDIS_URL=redis://:sentra_redis_password@localhost:6380
CACHE_TTL=300

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Comm Service - MongoDB
MONGO_URI=mongodb://sentra_mongo_user:sentra_mongo_password@localhost:27017/sentra_comm?authSource=admin

# Comm Service - Gmail OAuth
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3002/api/comm/identities/oauth/callback

# Comm Service - Token Encryption (32-byte hex key)
COMM_ENCRYPTION_MASTER_KEY=change-me-must-be-64-hex-chars-0000000000000000000000000000000000

# Comm Service - S3 Attachment Archival (leave S3_BUCKET empty to disable)
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=

# Comm Service - Internal Service Secret
INTERNAL_SERVICE_SECRET=change-me-in-production

# Comm Service - Core Service URL (for contact lookup)
CORE_SERVICE_URL=http://localhost:3001
